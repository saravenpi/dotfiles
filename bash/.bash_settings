# shellcheck shell=bash
# history
HISTCONTROL=ignoreboth

# default editor
export EDITOR='nvim'

# colored GCC warnings and errors
export GCC_COLORS='error=01;31:warning=01;35:note=01;36:caret=01;32:locus=01:quote=01'

# local bins
export MYBINS="$HOME/mybins"
[ -d "$MYBINS" ] && export PATH="$MYBINS:$PATH"

case "$(uname -s)" in
    Darwin)
        export HOMEBREW_CASK_OPTS="--fontdir=$HOME/.fonts"
        [ -d "$HOME/Library/Android/sdk" ] && export ANDROID_HOME="$HOME/Library/Android/sdk"
        ;;
    Linux)
        [ -d "$HOME/Android/Sdk" ] && export ANDROID_HOME="$HOME/Android/Sdk"
        [ -z "${ANDROID_HOME:-}" ] && [ -d "$HOME/Android/sdk" ] && export ANDROID_HOME="$HOME/Android/sdk"
        ;;
esac

[ -n "${ANDROID_HOME:-}" ] && [ -d "$ANDROID_HOME/platform-tools" ] && export PATH="$PATH:$ANDROID_HOME/platform-tools"
[ -d "$HOME/.cargo/bin" ] && export PATH="$HOME/.cargo/bin:$PATH"
[ -d "$HOME/.local/share/bob/nvim-bin" ] && export PATH="$PATH:$HOME/.local/share/bob/nvim-bin"

export MANPAGER="nvim +Man!"
export TLDR_AUTO_UPDATE_DISABLED="true"
