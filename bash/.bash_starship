__main() {
	local starship_bin
	local major="${BASH_VERSINFO[0]}"
	local minor="${BASH_VERSINFO[1]}"

	starship_bin="$(command -v starship 2>/dev/null || true)"
	[[ -n "$starship_bin" ]] || return 0

	if ((major > 4)) || { ((major == 4)) && ((minor >= 1)); }; then
		source <("$starship_bin" init bash --print-full-init)
	else
		source /dev/stdin <<<"$("$starship_bin" init bash --print-full-init)"
	fi
}
__main
unset -f __main
