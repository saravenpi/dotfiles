#!/bin/bash

# rm alias
alias rm="rip"

# cat alias
alias cat="bat"

# ls aliases
alias ls="eza --color=always --git --icons=always --no-user"
alias tn="eza --tree --color=always --git --icons=always --no-user"
alias ll="ls -lh"
alias la="ls -ah"
alias lal="ls -alh"
alias lla="ls -alh"
alias l="ls"

# jobs
alias f="fg"

# file permissions
alias ax="chmod +x"
alias rx="chmod -x"

# shell commands
alias q="exit"
alias :q="exit"
alias c="clear"
alias hc="history clear"
alias breload='clear && source $HOME/.bashrc'
alias brel="breload"
alias zreload='clear && source $HOME/.zshrc'
alias zrel="zreload"
alias treload="tmux source-file ~/.tmux.conf"
alias trel="treload"

# quick navigation
alias h='clear && cd $HOME'
alias dots='cd $HOME/.dotfiles'
alias goc='cd $HOME/Code/'
alias gos='cd $HOME/Code/School'
alias gob='cd $HOME/brain/'
alias gon='cd $HOME/notes/ && nvim index.md'
alias brain='cd "$BRAIN/" && nvim Home.md'
alias b='cd "$BRAIN/" && nvim Home.md'

# quick config
alias cnvim='cd $HOME/.config/nvim/ && nvim .'
alias cbash='cd $HOME && nvim .bashrc'
alias czsh='cd $HOME && nvim .zshrc'
alias caliases='cd $HOME && nvim .aliases'
alias cfunctions='cd $HOME && nvim .functions'
alias ctmux='cd $HOME && nvim .tmux.conf'
alias cghostty='cd $HOME/.config/ghostty/ && nvim config'
alias ckitty='cd $HOME/.config/kitty/ && nvim kitty.conf'
alias cterminal='cd $HOME/.config/ghostty/ && nvim config'
alias cportals='cd $HOME/portals && nvim .'
alias cclaude='cd $HOME/.claude && nvim .'

# git aliases
alias gs="git status"
alias gp="git push"
alias ga="git add"
alias gc="git clone"
alias gd="git diff"
alias gb="git branch"
alias gba="git branch -a"
alias gco="git checkout"
alias gr="git remove"
alias gitu="git add . && git commit"
alias gitup="git add . && git commit && git push"
alias gituf='git add . && git commit -m "$(date +"%Y-%m)-%d %T")" && git push'

# clang
alias m="make"
alias mc="make clean"
alias mf="make fclean"
alias mfc="make fclean"
alias mr="make re"
alias mre="mr"
alias vg="valgrind"
alias vgf="valgrind --leak-check=full"
alias cinit="kettle use c ."

# tmux
alias tl="tmux ls -f '#{session_name}'" # list sessions
alias sl="tmux ls -f '#{session_name}'" # list sessions
alias tll="tmux ls"                     # list sessions with details
alias trs="tmux rename-session -t"      # remame tmux session

# cli apps
alias e="egg"
alias w="wisp"
alias d="donut"
alias p="purse i"
alias v="vero"

# code
alias n="nvim"
alias cy="claude --dangerously-skip-permissions"
alias k="knot"
alias t="tmux"

# fun
alias starwars="telnet towel.blinkenlights.nl"
