#!/bin/bash

# saves the current path for quick access
setp() {
    skatos set current_project "$(pwd)"
}

# goes to the saved project path
gop() {
    cd $(skatos get current_project)
}

# quick cd with zoxide
z() {
	local args=("$@")
	tmppath=$(zoxide query $args)
	echo $tmppath
	if [[ -z $tmppath ]]; then
		echo "No such project"
	else
		cd $tmppath
	fi
	unset tmppath
}

# zoxide to the path and opens it with nvimgp
grp() {
	z $1
	nvim .
}

# o : zoxide → egg → retour maison
o() {
    local origin="$PWD"

    if [[ $# -eq 0 || "$1" == "." ]]; then
        egg "$(basename "$origin")"
    else
        z "$@" || return
        egg "$(basename "$PWD")"
    fi

    cd "$origin"
    unset origin
}


op() {
  tmppath=$(cat ~/.project)
	cd $tmppath
  egg
	unset tmppath
}

oe() {
	cur=$(pwd)
	z $1
	epi $1
	cd $cur
	unset cur
}

gss() {
	echo "Untracked files:"
	git status --porcelain | grep '^??' | wc -l
	echo "Staged files:"
	git status --porcelain | grep '^[ MD]' | wc -l
	echo "Lines of code:"
	tokei --output yaml | yq '.Total.code'
}

gcs() {
	git clone "git@github.com:$1.git"
}

s() {
    if [ -n "$TMUX" ]; then
        TMUX_COMMAND="switch-client"
    else
        TMUX_COMMAND="attach-session"
    fi

    if [ "$#" -eq 0 ]; then
        active_sessions=$(tmux list-sessions -F "#{session_last_attached} #{session_name}" 2>/dev/null | sort -rn | awk '{print $2}')

        all_options="$active_sessions"

        session=$(echo "$all_options" | fzf --prompt="Select or create tmux session: " --height=40% --border --print-query | tail -1)

        if [ -z "$session" ]; then
            return 0
        fi

        session=$(echo "$session" | xargs)

        if tmux has-session -t "$session" 2>/dev/null; then
            tmux $TMUX_COMMAND -t "$session"
            return 0
        fi

        project_path=$(zoxide query "$session" 2>/dev/null)

        if [ -z "$project_path" ]; then
            project_path=$(zoxide query --list | grep -i "$session" | head -1)
        fi

        if [ -z "$project_path" ]; then
            if [ -d "$session" ]; then
                project_path=$(cd "$session" && pwd)
                zoxide add "$project_path" 2>/dev/null
            else
                project_path="$(pwd)"
            fi
        fi

        if [ ! -d "$project_path" ]; then
            project_path="$(pwd)"
        fi

        tmux new-session -d -s "$session" -c "$project_path"

        if [ -f "$project_path/egg.yml" ]; then
            tmux send-keys -t "$session" 'egg --current' Enter
        fi

        tmux $TMUX_COMMAND -t "$session"
    else
        if tmux has-session -t "$1" 2>/dev/null; then
            tmux $TMUX_COMMAND -t "$1"
        else
            project_path=$(zoxide query "$1" 2>/dev/null)

            if [ -z "$project_path" ]; then
                project_path=$(zoxide query --list | grep -i "$1" | head -1)
            fi

            if [ -z "$project_path" ]; then
                if [ -d "$1" ]; then
                    project_path=$(cd "$1" && pwd)
                    zoxide add "$project_path" 2>/dev/null
                else
                    project_path="$(pwd)"
                fi
            fi

            if [ ! -d "$project_path" ]; then
                project_path="$(pwd)"
            fi

            tmux new-session -d -s "$1" -c "$project_path"

            if [ -f "$project_path/egg.yml" ]; then
                tmux send-keys -t "$1" 'egg --current' Enter
            fi

            tmux $TMUX_COMMAND -t "$1"
        fi
    fi
}


killport() {
  if [ -z "$1" ]; then
    echo "Usage: killport <port>"
    return 1
  fi

  PID=$(lsof -ti tcp:$1)

  if [ -z "$PID" ]; then
    echo "🔍 No process found on port $1"
  else
    kill -9 $PID && echo "💥 Port $1 freeed (PID $PID killed)"
  fi
}


tellme() {
				curl -s -d "$1" "$NTFY_SH" > /dev/null && echo "📱 Notification sent successfully! ✨" || echo "❌ Failed to send notification"
}

clean_node_modules() {
    local current_dir="${1:-$(pwd)}"

    echo "🔍 Searching for root-level node_modules directories..."

    local node_modules_dirs=()
    while IFS= read -r -d '' dir; do
        if [[ ! "$dir" =~ /node_modules/.*/node_modules$ ]]; then
            node_modules_dirs+=("$dir")
        fi
    done < <(fd -t d -H '^node_modules$' "$current_dir" -0 2>/dev/null)

    if [ ${#node_modules_dirs[@]} -eq 0 ]; then
        echo "✅ No root-level node_modules directories found."
        return 0
    fi

    echo "📦 Found ${#node_modules_dirs[@]} root-level node_modules directories:"
    printf '%s\n' "${node_modules_dirs[@]}"
    echo

    local total_size=$(du -sh "${node_modules_dirs[@]}" 2>/dev/null | awk '{sum += $1} END {print sum "M"}' 2>/dev/null || echo "unknown")

    if gum confirm "🗑️  Delete all ${#node_modules_dirs[@]} root-level node_modules directories? (Total size: ~$total_size)"; then
        echo "🧹 Cleaning up node_modules directories..."

        for dir in "${node_modules_dirs[@]}"; do
            echo "  Removing: $dir"
            rip "$dir"
        done

        echo "✅ All root-level node_modules directories have been removed!"
    else
        echo "❌ Operation cancelled."
        return 1
    fi
}

setwallpaper() {
    local all_spaces=false
    local image_path=""
    local max_spaces=10

    while [[ $# -gt 0 ]]; do
        case $1 in
            -a|--all-spaces)
                all_spaces=true
                shift
                ;;
            *)
                image_path="$1"
                shift
                ;;
        esac
    done

    if [ -z "$image_path" ]; then
        echo "Usage: setwallpaper [-a|--all-spaces] <image_path>"
        echo "  -a, --all-spaces    Set wallpaper across all spaces/workspaces"
        return 1
    fi

    if [ ! -f "$image_path" ]; then
        echo "Error: File '$image_path' not found"
        return 1
    fi

    local abs_path=$(cd "$(dirname "$image_path")" && pwd)/$(basename "$image_path")

    if [ "$all_spaces" = true ]; then
        echo "Setting wallpaper across all spaces and screens..."

        osascript -e "tell application \"System Events\" to tell every desktop to set picture to \"$abs_path\"" 2>/dev/null
        sleep 0.3

        for i in $(seq 1 $max_spaces); do
            osascript -e "tell application \"System Events\" to key code 124 using control down" 2>/dev/null
            sleep 0.5

            osascript -e "tell application \"System Events\" to tell every desktop to set picture to \"$abs_path\"" 2>/dev/null
            sleep 0.3
        done

        echo "✓ Wallpaper set across all spaces to: $abs_path"
    else
        osascript -e "tell application \"System Events\" to tell every desktop to set picture to \"$abs_path\""

        if [ $? -eq 0 ]; then
            echo "✓ Wallpaper set to: $abs_path"
        else
            echo "✗ Failed to set wallpaper"
            return 1
        fi
    fi
}

disk() {
    local CYAN='\033[0;36m'
    local GREEN='\033[0;32m'
    local YELLOW='\033[1;33m'
    local RED='\033[0;31m'
    local RESET='\033[0m'
    local BOLD='\033[1m'

    df -h | grep -E '^/dev/' | grep -v '/System/Volumes' | while read -r line; do
        local disk=$(echo $line | awk '{print $1}')
        local avail=$(echo $line | awk '{print $4}')
        local mount=$(echo $line | awk '{print $9}')

        local disk_name=$(basename "$disk")
        if [ -n "$mount" ] && [ "$mount" != "/" ]; then
            disk_name="$disk_name ($mount)"
        fi

        local size=$(echo $avail | sed 's/Gi/GB/g; s/Mi/MB/g; s/Ki/KB/g; s/Ti/TB/g')

        local size_num=$(echo $size | sed 's/[^0-9.]//g')
        local size_unit=$(echo $size | sed 's/[0-9.]//g')

        local color=$GREEN
        if [ "$size_unit" = "GB" ] && [ "$(echo "$size_num < 50" | bc -l 2>/dev/null || echo 0)" = "1" ]; then
            color=$YELLOW
        elif [ "$size_unit" = "GB" ] && [ "$(echo "$size_num < 20" | bc -l 2>/dev/null || echo 0)" = "1" ]; then
            color=$RED
        elif [ "$size_unit" = "MB" ]; then
            color=$RED
        fi

        echo -e "💾 ${CYAN}${BOLD}${disk_name}${RESET}: ${color}${BOLD}${size}${RESET} left"
    done
}

bnn() {
    cd "$BRAIN"
    local filename=$(echo "$@" | tr ' ' '_')
    touch "Inbox/${filename}.md"
    nvim "Inbox/${filename}.md"
}

toggle-theme() {
    local current_theme=""
    local new_theme=""

    if grep -q "include.*themes/paper-dark.conf" ~/.dotfiles/kitty/.config/kitty/kitty.conf 2>/dev/null; then
        current_theme="dark"
        new_theme="light"
    else
        current_theme="light"
        new_theme="dark"
    fi

    echo "🎨 Switching from $current_theme to $new_theme mode..."

    if [ "$new_theme" = "dark" ]; then
        sed -i '' 's|include.*themes/paper.*\.conf|include                 themes/paper-dark.conf|' ~/.dotfiles/kitty/.config/kitty/kitty.conf

        sed -i '' 's|set -g @paper_theme ".*"|set -g @paper_theme "dark"|' ~/.dotfiles/tmux/.tmux.conf

        export FZF_DEFAULT_OPTS="--color=fg:#e8dcc8,bg:#2a1f1a,hl:#d4923a,fg+:#f5eee0,bg+:#3d2d22,hl+:#d4923a,info:#7a9048,prompt:#c47f2c,pointer:#d4923a,marker:#8ca558,spinner:#5f8f76,header:#5a7f94"

        echo "dark" > ~/.theme_mode
    else
        sed -i '' 's|include.*themes/paper.*\.conf|include                 themes/paper.conf|' ~/.dotfiles/kitty/.config/kitty/kitty.conf

        sed -i '' 's|set -g @paper_theme ".*"|set -g @paper_theme "light"|' ~/.dotfiles/tmux/.tmux.conf

        export FZF_DEFAULT_OPTS="--color=fg:#4a3728,bg:#faf6f0,hl:#c47f2c,fg+:#3a2818,bg+:#e8dcc8,hl+:#c47f2c,info:#6a7d3e,prompt:#b04c3f,pointer:#c47f2c,marker:#7a9048,spinner:#507964,header:#4d6c7d"

        echo "light" > ~/.theme_mode
    fi

    if [ -n "$KITTY_PID" ]; then
        kill -SIGUSR1 $KITTY_PID 2>/dev/null
    fi

    if [ -n "$TMUX" ]; then
        tmux source-file ~/.tmux.conf 2>/dev/null
    fi

    for server in $(nvim --serverlist 2>/dev/null); do
        nvim --server "$server" --remote-send "<Cmd>lua vim.opt.background='$new_theme'<CR><Cmd>colorscheme paper<CR>" 2>/dev/null || true
    done

    echo "✨ Theme switched to $new_theme mode!"
    echo "💡 In nvim, run :colorscheme paper to apply theme change"
}

